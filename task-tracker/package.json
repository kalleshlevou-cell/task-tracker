{
  "name": "task-tracker",
  "version": "1.0.0",
  "description": "MERN Stack Task Tracker",
  "scripts": {
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "npm install --prefix server && npm install --prefix client --legacy-peer-deps",
    "build": "npm run build --prefix client",
    "deploy:pages": "npm run build && gh-pages -d client/dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
